<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Teal outer glow -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="40dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#5500E5CC"
                android:endColor="#00000000" />
            <size android:width="80dp" android:height="80dp" />
        </shape>
    </item>

    <!-- Teal ring -->
    <item android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="oval">
            <stroke android:width="2.5dp" android:color="#DD00E5CC" />
            <solid android:color="#E60A0A0A" />
            <size android:width="64dp" android:height="64dp" />
        </shape>
    </item>

    <!-- Double ring accent -->
    <item android:left="16dp" android:top="16dp" android:right="16dp" android:bottom="16dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#4400E5CC" />
            <solid android:color="#00000000" />
            <size android:width="48dp" android:height="48dp" />
        </shape>
    </item>

    <!-- Outer core ring -->
    <item android:left="26dp" android:top="26dp" android:right="26dp" android:bottom="26dp">
        <shape android:shape="oval">
            <stroke android:width="1.5dp" android:color="#8800E5CC" />
            <solid android:color="#00000000" />
            <size android:width="28dp" android:height="28dp" />
        </shape>
    </item>

    <!-- Core dot — teal -->
    <item android:left="33dp" android:top="33dp" android:right="33dp" android:bottom="33dp">
        <shape android:shape="oval">
            <solid android:color="#CC00E5CC" />
            <size android:width="14dp" android:height="14dp" />
        </shape>
    </item>

</layer-list>
