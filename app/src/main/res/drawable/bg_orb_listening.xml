<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Bright outer glow -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="40dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#6600D4FF"
                android:endColor="#00000000" />
            <size android:width="80dp" android:height="80dp" />
        </shape>
    </item>

    <!-- Bright ring -->
    <item android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="oval">
            <stroke android:width="3dp" android:color="#FF00D4FF" />
            <solid android:color="#E60A0A0A" />
            <size android:width="64dp" android:height="64dp" />
        </shape>
    </item>

    <!-- Inner ring accent -->
    <item android:left="18dp" android:top="18dp" android:right="18dp" android:bottom="18dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#5500D4FF" />
            <solid android:color="#00000000" />
            <size android:width="44dp" android:height="44dp" />
        </shape>
    </item>

    <!-- Core dot — bright -->
    <item android:left="30dp" android:top="30dp" android:right="30dp" android:bottom="30dp">
        <shape android:shape="oval">
            <solid android:color="#FF00D4FF" />
            <size android:width="20dp" android:height="20dp" />
        </shape>
    </item>

</layer-list>
