<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer glow — green shift -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="40dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#5500FF87"
                android:endColor="#00000000" />
            <size android:width="80dp" android:height="80dp" />
        </shape>
    </item>

    <!-- Gradient ring — cyan to green -->
    <item android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="oval">
            <stroke android:width="3dp" android:color="#FF00FF87" />
            <solid android:color="#E60A0A0A" />
            <size android:width="64dp" android:height="64dp" />
        </shape>
    </item>

    <!-- Pulse ring -->
    <item android:left="14dp" android:top="14dp" android:right="14dp" android:bottom="14dp">
        <shape android:shape="oval">
            <stroke android:width="1.5dp" android:color="#4400FF87" />
            <solid android:color="#00000000" />
            <size android:width="52dp" android:height="52dp" />
        </shape>
    </item>

    <!-- Core dot — green -->
    <item android:left="30dp" android:top="30dp" android:right="30dp" android:bottom="30dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="10dp"
                android:startColor="#FF00FF87"
                android:endColor="#FF00D4FF" />
            <size android:width="20dp" android:height="20dp" />
        </shape>
    </item>

</layer-list>
