<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="32dp">

    <!-- Logo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="@color/primary"
        android:textSize="72sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginTop="48dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Zero"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="monospace" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="40dp" />

    <!-- Session Proxy URL -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Session Proxy URL"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/inputProxyUrl"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_settings_input"
        android:hint="http://192.168.1.x:11435"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:textSize="15sp"
        android:paddingHorizontal="16dp"
        android:singleLine="true"
        android:inputType="textUri" />

    <!-- Save button -->
    <TextView
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_pair_button"
        android:gravity="center"
        android:text="Save"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="24dp"
        android:background="@color/text_secondary"
        android:alpha="0.2" />

    <!-- MCP Server section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MCP Tool Server"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/mcpAddressLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MCP server stopped"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/btnMcpToggle"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_settings_input"
        android:gravity="center"
        android:text="Start MCP Server"
        android:textColor="@color/primary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="monospace" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="24dp"
        android:background="@color/text_secondary"
        android:alpha="0.2" />

    <!-- T0ggles Workflow section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="T0ggles Workflow"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/t0gglesStatusLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Workflow tools not loaded"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp" />

    <!-- T0ggles API Key -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="API Key"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/inputT0gglesApiKey"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_settings_input"
        android:hint="t0mcp_..."
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:textSize="15sp"
        android:paddingHorizontal="16dp"
        android:singleLine="true"
        android:inputType="textPassword" />

    <!-- T0ggles Board ID -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Board ID"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/inputT0gglesBoardId"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_settings_input"
        android:hint="board ID"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:textSize="15sp"
        android:paddingHorizontal="16dp"
        android:singleLine="true"
        android:inputType="text" />

    <!-- T0ggles URL -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MCP URL"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/inputT0gglesUrl"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_settings_input"
        android:hint="https://t0ggles.com/mcp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:textSize="15sp"
        android:paddingHorizontal="16dp"
        android:singleLine="true"
        android:inputType="textUri" />

    <!-- T0ggles buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/btnSaveT0ggles"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_pair_button"
            android:gravity="center"
            android:text="Save T0ggles"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnRefreshTools"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_settings_input"
            android:gravity="center"
            android:text="Refresh Tools"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="24dp"
        android:background="@color/text_secondary"
        android:alpha="0.2" />

    <!-- Scheduled Tasks section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Scheduled Tasks"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/scheduledStatusLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Disabled"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/btnScheduledToggle"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_settings_input"
        android:gravity="center"
        android:text="Enable Scheduled Checks"
        android:textColor="@color/primary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="monospace" />

    <!-- Interval -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Check Interval (hours)"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/inputScheduledInterval"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_settings_input"
        android:hint="1"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:textSize="15sp"
        android:paddingHorizontal="16dp"
        android:singleLine="true"
        android:inputType="number" />

    <!-- Auto-execute toggle -->
    <TextView
        android:id="@+id/btnAutoExecuteToggle"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_settings_input"
        android:gravity="center"
        android:text="Enable Auto-Execute"
        android:textColor="@color/primary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="monospace" />

    <!-- Check Now button -->
    <TextView
        android:id="@+id/btnCheckNow"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_pair_button"
        android:gravity="center"
        android:text="Check Now"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
</ScrollView>
