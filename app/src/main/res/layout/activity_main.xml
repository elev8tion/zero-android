<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Zero"
            android:textColor="@color/primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings"
            android:padding="4dp" />
    </LinearLayout>

    <!-- Status cards -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Accessibility service card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_settings_input"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accessibility Service"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/statusAccessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Checking..."
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- MCP server card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_settings_input"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MCP Tool Server"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/statusMcp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Stopped"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Session proxy card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_settings_input"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Session Proxy"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/statusProxy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Not configured"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Permissions card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_settings_input"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Permissions"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/statusPermissions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Checking..."
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Enable accessibility button (shown only when service is off) -->
            <TextView
                android:id="@+id/btnEnableAccessibility"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center"
                android:background="@drawable/bg_pair_button"
                android:text="Enable Accessibility Service"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <!-- Grant Permissions button (shown only when permissions are missing) -->
            <TextView
                android:id="@+id/btnGrantPermissions"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center"
                android:background="@drawable/bg_pair_button"
                android:text="Grant Permissions"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <!-- Start / Stop overlay button -->
            <TextView
                android:id="@+id/btnOverlay"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center"
                android:background="@drawable/bg_pair_button"
                android:text="Start Overlay"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
